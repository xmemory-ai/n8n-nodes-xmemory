{
    "name": "n8n-nodes-xmemory",
    "version": "0.1.2",
    "description": "n8n node for xmemory read/write operations",
    "license": "MIT",
    "homepage": "https://github.com/xmemory-ai/n8n-nodes-xmemory",
    "keywords": [
        "n8n-community-node-package",
        "n8n",
        "xmemory",
        "memory"
    ],
    "author": {
        "name": "Alexander Gusak",
        "email": "alexg@xmemory.ai"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/xmemory-ai/n8n-nodes-xmemory"
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "prepublishOnly": "n8n-node prerelease"
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": true,
        "credentials": [
            "dist/credentials/XmemoryApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/Xmemory/Xmemory.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "*",
        "eslint": "9.32.0",
        "prettier": "3.6.2",
        "release-it": "^19.0.4",
        "typescript": "5.9.2"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    }
}
